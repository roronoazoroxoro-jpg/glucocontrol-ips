# Local development
DATABASE_URL="file:./dev.db"

# Auth — generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-por-secreto-largo-en-produccion"

# Production (Turso via Vercel integration)
TURSO_DATABASE_URL="libsql://your-db-name-user.turso.io"
TURSO_AUTH_TOKEN="your-token"

USDA_API_KEY=DEMO_KEY

# Análisis de foto de comida por IA (opcional — si no hay ninguna, se usa
# el reconocimiento en el propio celular, sin claves).
# Google Gemini (RECOMENDADO, gratis: https://aistudio.google.com/app/apikey)
# Modelo usado: gemini-2.5-flash (1500 análisis/día gratis)
GEMINI_API_KEY=""
# OpenAI (alternativa, de pago) — gpt-4o
OPENAI_API_KEY=""

EDAMAM_APP_ID=""
EDAMAM_APP_KEY=""
